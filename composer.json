{
    "name": "hamm/bbbug",
    "description": "Fast build your php project",
    "type": "project",
    "keywords": [
        "BBBUG"
    ],
    "homepage": "https://music.eggedu.cn/",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Hamm",
            "email": "admin@hamm.cn"
        }
    ],
    "require": {
        "php": "^8.1",
        "topthink/framework": "^8.1.4",
        "topthink/think-orm": "^4.0",
        "topthink/think-multi-app": "^1.1",
        "topthink/think-view": "^2.0",
        "w7corp/easywechat": "^6.17",
        "topthink/think-image": "^1.0",
        "phpmailer/phpmailer": "^6.1",
        "metowolf/meting": "^1.5",
        "topthink/think-filesystem": "^3.0"
    },
    "require-dev": {
        "symfony/var-dumper": "^6.0",
        "topthink/think-trace": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app"
        },
        "psr-0": {
            "": "extend/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "allow-plugins": {
            "easywechat-composer/easywechat-composer": true
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php think service:discover",
            "@php think vendor:publish"
        ]
    }
}
